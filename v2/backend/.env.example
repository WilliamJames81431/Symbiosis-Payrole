# =============================================================
# SYMBIOSIS ENTERPRISE HRMS v2.0 — Backend Environment Variables
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# ─── APPLICATION ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v2
FRONTEND_URL=http://localhost:5173

# ─── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=postgresql://symbiosis:symbiosis_dev_pass@localhost:5432/symbiosis_hrms?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── REDIS ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=symbiosis_redis_pass
REDIS_TLS=false

# ─── JWT AUTHENTICATION ─────────────────────────────────────────
# Generate with: openssl genrsa -out private.key 2048 && openssl rsa -in private.key -pubout -out public.key
JWT_PRIVATE_KEY_PATH=./keys/private.key
JWT_PUBLIC_KEY_PATH=./keys/public.key
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ─── FIELD ENCRYPTION ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used for PAN, Aadhaar, Bank Account numbers
FIELD_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_change_in_prod

# ─── STORAGE (MinIO / AWS S3) ─────────────────────────────────
STORAGE_PROVIDER=minio   # minio | s3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=symbiosis_minio
MINIO_SECRET_KEY=symbiosis_minio_pass
MINIO_BUCKET=symbiosis-documents

# AWS S3 (production)
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# S3_BUCKET=symbiosis-documents-prod

# ─── EMAIL ─────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp    # smtp | ses | sendgrid
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Symbiosis HRMS
EMAIL_FROM_ADDRESS=noreply@symbiosishrms.com

# ─── SMS (MSG91) ───────────────────────────────────────────────
SMS_PROVIDER=msg91    # msg91 | twilio | disabled
MSG91_AUTH_KEY=your_msg91_key
MSG91_SENDER_ID=SYMBIO
MSG91_DLT_TEMPLATE_OTP=your_dlt_template_id

# ─── PDF SERVICE ───────────────────────────────────────────────
PDF_SERVICE_URL=http://localhost:5000
PDF_SERVICE_SECRET=change_this_in_production

# ─── RATE LIMITING ─────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
LOGIN_THROTTLE_TTL=900000   # 15 minutes
LOGIN_THROTTLE_LIMIT=5

# ─── LOGGING ───────────────────────────────────────────────────
LOG_LEVEL=debug    # error | warn | log | debug | verbose
LOG_FORMAT=pretty  # pretty | json

# ─── PLATFORM ──────────────────────────────────────────────────
PLATFORM_SUPER_ADMIN_EMAIL=superadmin@symbiosishrms.com
PLATFORM_SUPER_ADMIN_PASSWORD=Change_This_Immediately_2026!

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
