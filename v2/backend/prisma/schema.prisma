// ============================================================
// SYMBIOSIS ENTERPRISE HRMS v2.0 — Prisma Schema
// PostgreSQL 16 | 65 Tables | Row Level Security
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, uuidOssp(map: "uuid-ossp"), pgTrgm(map: "pg_trgm")]
}

// ============================================================
// ENUMS
// ============================================================

enum OrgStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum OrgPlan {
  STARTER
  GROWTH
  ENTERPRISE
  ENTERPRISE_PLUS
}

enum UserRole {
  SUPER_ADMIN
  ERP_ADMIN
  ORG_ADMIN
  HR_MANAGER
  PAYROLL_MANAGER
  RECRUITER
  DEPT_MANAGER
  TEAM_LEADER
  EMPLOYEE
  AUDITOR
  ACCOUNTANT
  VENDOR
  CONTRACTOR
  READ_ONLY
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_ACTIVATION
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  CONSULTANT
}

enum EmploymentStatus {
  DRAFT
  ACTIVE
  ON_PROBATION
  CONFIRMED
  ON_NOTICE
  RESIGNED
  TERMINATED
  ABSCONDED
  RETIRED
  SUSPENDED
  ON_LONG_LEAVE
  DECEASED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum AttendanceStatus {
  P     // Present
  A     // Absent
  H     // Half Day First Half
  H2    // Half Day Second Half
  WO    // Weekly Off
  PH    // Public Holiday
  CO    // Comp Off
  EL    // Earned Leave
  SL    // Sick Leave
  CL    // Casual Leave
  ML    // Maternity Leave
  PL    // Paternity Leave
  BL    // Bereavement Leave
  LWP   // Leave Without Pay
  WFH   // Work From Home
  BT    // Business Travel
  OD    // On Duty
  TR    // Training
  NS    // Night Shift
  LA    // Late Arrival
  EE    // Early Exit
}

enum AttendanceSource {
  MANUAL
  CSV_UPLOAD
  BIOMETRIC
  GPS
  QR_CODE
}

enum LeaveStatus {
  PENDING
  L1_APPROVED
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum LeaveAccrualType {
  ANNUAL
  MONTHLY
  QUARTERLY
}

enum PayrollStatus {
  DRAFT
  CALCULATING
  SANDBOX
  PENDING_APPROVAL
  APPROVED
  LOCKED
  REVISED
}

enum ComponentType {
  EARNING
  DEDUCTION
  EMPLOYER_CONTRIBUTION
  INFORMATIONAL
}

enum ComponentCalculationType {
  FIXED
  PERCENTAGE_OF_BASIC
  PERCENTAGE_OF_GROSS
  FORMULA
  STATUTORY
}

enum SalaryRevisionType {
  INITIAL
  INCREMENT
  PROMOTION
  ADHOC
  CORRECTION
}

enum LoanStatus {
  PENDING
  APPROVED
  DISBURSED
  CLOSED
  CANCELLED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExitReason {
  RESIGNATION
  TERMINATION
  RETIREMENT
  ABSCONDING
  REDUNDANCY
  DEATH
  OTHER
}

enum ExitStatus {
  PENDING
  ACCEPTED
  COUNTER_OFFERED
  WITHDREW
  IN_PROGRESS
  COMPLETED
}

enum DocumentCategory {
  IDENTITY
  EMPLOYMENT
  EDUCATION
  EXPERIENCE
  COMPLIANCE
  PAYROLL
  EXIT
  COMPANY
}

enum TaxRegime {
  OLD
  NEW
}

enum AnnouncementType {
  GENERAL
  POLICY
  URGENT
  EVENT
  CELEBRATION
}

// ============================================================
// DOMAIN 1: PLATFORM & TENANCY
// ============================================================

model Organization {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgCode               String    @unique @map("org_code") @db.VarChar(20)
  legalName             String    @map("legal_name") @db.VarChar(200)
  tradeName             String?   @map("trade_name") @db.VarChar(200)
  cin                   String?   @unique @db.VarChar(21)
  pan                   String    @unique @db.VarChar(10)
  tan                   String?   @db.VarChar(10)
  gstNumber             String?   @map("gst_number") @db.VarChar(15)
  epfEstablishmentNo    String?   @map("epf_establishment_no") @db.VarChar(20)
  esiCode               String?   @map("esi_code") @db.VarChar(20)
  primaryContactName    String    @map("primary_contact_name") @db.VarChar(100)
  primaryContactEmail   String    @unique @map("primary_contact_email") @db.VarChar(200)
  primaryContactPhone   String    @map("primary_contact_phone") @db.VarChar(15)
  addressLine1          String    @map("address_line1") @db.VarChar(200)
  addressLine2          String?   @map("address_line2") @db.VarChar(200)
  city                  String    @db.VarChar(100)
  state                 String    @db.VarChar(50)
  pincode               String    @db.VarChar(10)
  country               String    @default("India") @db.VarChar(50)
  industry              String?   @db.VarChar(100)
  businessType          String?   @map("business_type") @db.VarChar(50)
  employeeCountRange    String?   @map("employee_count_range") @db.VarChar(20)
  status                OrgStatus @default(TRIAL)
  plan                  OrgPlan   @default(STARTER)
  trialEndsAt           DateTime? @map("trial_ends_at") @db.Timestamptz
  subscriptionStartsAt  DateTime? @map("subscription_starts_at") @db.Timestamptz
  logoUrl               String?   @map("logo_url")
  brandColorPrimary     String?   @map("brand_color_primary") @db.VarChar(7)
  brandColorSecondary   String?   @map("brand_color_secondary") @db.VarChar(7)
  fiscalYearStart       String    @default("APRIL") @map("fiscal_year_start") @db.VarChar(10)
  payDay                Int       @default(1) @map("pay_day") @db.SmallInt
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  branches              Branch[]
  departments           Department[]
  teams                 Team[]
  costCenters           CostCenter[]
  grades                Grade[]
  designations          Designation[]
  locations             Location[]
  shiftMasters          ShiftMaster[]
  holidayCalendars      HolidayCalendar[]
  leaveTypes            LeaveType[]
  salaryComponents      SalaryComponent[]
  salaryStructures      SalaryStructure[]
  employees             Employee[]
  userAccounts          UserAccount[]
  payrollRuns           PayrollRun[]
  orgSettings           OrgSetting[]
  announcements         Announcement[]
  documents             Document[]
  jobPostings           JobPosting[]
  billingSubscriptions  BillingSubscription[]

  @@map("organizations")
}

model BillingSubscription {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  plan             String   @db.VarChar(20)
  billingCycle     String   @default("MONTHLY") @map("billing_cycle") @db.VarChar(10)
  employeeLimit    Int      @map("employee_limit")
  pricePerEmployee Decimal  @map("price_per_employee") @db.Decimal(8, 2)
  currency         String   @default("INR") @db.VarChar(3)
  startsAt         DateTime @map("starts_at") @db.Timestamptz
  endsAt           DateTime? @map("ends_at") @db.Timestamptz
  status           String   @default("ACTIVE") @db.VarChar(20)
  razorpaySubId    String?  @map("razorpay_sub_id") @db.VarChar(100)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  org              Organization @relation(fields: [orgId], references: [id])

  @@map("billing_subscriptions")
}

// ============================================================
// DOMAIN 2: ORGANIZATION STRUCTURE
// ============================================================

model Branch {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  branchCode       String   @map("branch_code") @db.VarChar(20)
  branchName       String   @map("branch_name") @db.VarChar(200)
  addressLine1     String   @map("address_line1") @db.VarChar(200)
  addressLine2     String?  @map("address_line2") @db.VarChar(200)
  city             String   @db.VarChar(100)
  state            String   @db.VarChar(50)
  pincode          String   @db.VarChar(10)
  ptRegistrationNo String?  @map("pt_registration_no") @db.VarChar(30)
  shopEstRegNo     String?  @map("shop_est_reg_no") @db.VarChar(50)
  ptStateCode      String?  @map("pt_state_code") @db.VarChar(2)
  isHeadOffice     Boolean  @default(false) @map("is_head_office")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy        String?  @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  isDeleted        Boolean  @default(false) @map("is_deleted")

  org              Organization    @relation(fields: [orgId], references: [id])
  employees        Employee[]
  holidayCalendars HolidayCalendar[]
  locations        Location[]

  @@unique([orgId, branchCode])
  @@index([orgId])
  @@map("branches")
}

model Department {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  parentDeptId   String?  @map("parent_dept_id") @db.Uuid
  deptCode       String   @map("dept_code") @db.VarChar(20)
  deptName       String   @map("dept_name") @db.VarChar(200)
  costCenterId   String?  @map("cost_center_id") @db.Uuid
  hodEmployeeId  String?  @map("hod_employee_id") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  isDeleted      Boolean  @default(false) @map("is_deleted")

  org            Organization @relation(fields: [orgId], references: [id])
  parent         Department?  @relation("DeptHierarchy", fields: [parentDeptId], references: [id])
  children       Department[] @relation("DeptHierarchy")
  costCenter     CostCenter?  @relation(fields: [costCenterId], references: [id])
  employees      Employee[]
  teams          Team[]

  @@unique([orgId, deptCode])
  @@index([orgId])
  @@map("departments")
}

model Team {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  deptId      String   @map("dept_id") @db.Uuid
  teamName    String   @map("team_name") @db.VarChar(200)
  teamLeadId  String?  @map("team_lead_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  isDeleted   Boolean  @default(false) @map("is_deleted")

  org         Organization @relation(fields: [orgId], references: [id])
  department  Department   @relation(fields: [deptId], references: [id])
  employees   Employee[]

  @@index([orgId])
  @@map("teams")
}

model CostCenter {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  ccCode        String   @map("cc_code") @db.VarChar(20)
  ccName        String   @map("cc_name") @db.VarChar(200)
  description   String?
  budgetAmount  Decimal? @map("budget_amount") @db.Decimal(15, 2)
  managerId     String?  @map("manager_id") @db.Uuid
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  org           Organization @relation(fields: [orgId], references: [id])
  departments   Department[]
  employees     Employee[]

  @@unique([orgId, ccCode])
  @@map("cost_centers")
}

model Grade {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  gradeCode   String   @map("grade_code") @db.VarChar(20)
  gradeName   String   @map("grade_name") @db.VarChar(100)
  minCtc      Decimal? @map("min_ctc") @db.Decimal(12, 2)
  maxCtc      Decimal? @map("max_ctc") @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order") @db.SmallInt
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  org         Organization     @relation(fields: [orgId], references: [id])
  designations Designation[]
  employees   Employee[]
  salaryStructures SalaryStructure[]

  @@unique([orgId, gradeCode])
  @@map("grades")
}

model Designation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  gradeId         String?  @map("grade_id") @db.Uuid
  designationName String   @map("designation_name") @db.VarChar(200)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  org             Organization @relation(fields: [orgId], references: [id])
  grade           Grade?       @relation(fields: [gradeId], references: [id])
  employees       Employee[]

  @@unique([orgId, designationName])
  @@map("designations")
}

model Location {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  locationName String   @map("location_name") @db.VarChar(200)
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(50)
  isMetro      Boolean  @default(false) @map("is_metro")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  org          Organization @relation(fields: [orgId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  employees    Employee[]

  @@index([orgId])
  @@map("locations")
}

// ============================================================
// DOMAIN 3: AUTHENTICATION & SECURITY
// ============================================================

model UserAccount {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String?    @map("org_id") @db.Uuid
  employeeId          String?    @map("employee_id") @db.Uuid
  username            String     @unique @db.VarChar(100)
  email               String     @unique @db.VarChar(200)
  passwordHash        String     @map("password_hash")
  role                UserRole
  totpSecret          String?    @map("totp_secret")
  totpEnabled         Boolean    @default(false) @map("totp_enabled")
  backupCodes         Json?      @map("backup_codes")
  status              UserStatus @default(ACTIVE)
  emailVerified       Boolean    @default(false) @map("email_verified")
  emailVerifiedAt     DateTime?  @map("email_verified_at") @db.Timestamptz
  failedLoginCount    Int        @default(0) @map("failed_login_count") @db.SmallInt
  lockedUntil         DateTime?  @map("locked_until") @db.Timestamptz
  lastLoginAt         DateTime?  @map("last_login_at") @db.Timestamptz
  passwordChangedAt   DateTime?  @map("password_changed_at") @db.Timestamptz
  passwordHistory     Json       @default("[]") @map("password_history")
  timezone            String     @default("Asia/Kolkata") @db.VarChar(50)
  locale              String     @default("en-IN") @db.VarChar(10)
  theme               String     @default("light") @db.VarChar(10)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  createdBy           String?    @map("created_by") @db.Uuid
  isDeleted           Boolean    @default(false) @map("is_deleted")
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz

  org                 Organization?         @relation(fields: [orgId], references: [id])
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]

  @@index([orgId])
  @@index([email])
  @@map("user_accounts")
}

model Session {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @unique @map("refresh_token_hash")
  deviceId         String?  @map("device_id") @db.VarChar(100)
  deviceName       String?  @map("device_name") @db.VarChar(100)
  deviceType       String?  @map("device_type") @db.VarChar(20)
  browser          String?  @db.VarChar(50)
  os               String?  @db.VarChar(50)
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  city             String?  @db.VarChar(100)
  country          String?  @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastActiveAt     DateTime @default(now()) @map("last_active_at") @db.Timestamptz
  expiresAt        DateTime @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  isActive         Boolean  @default(true) @map("is_active")

  user             UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("sessions")
}

model PasswordResetToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash")
  type       String   @db.VarChar(20)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  usedAt     DateTime? @map("used_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user       UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model RolePermission {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  role       String   @db.VarChar(30)
  permission String   @db.VarChar(100)
  granted    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([orgId, role, permission])
  @@map("role_permissions")
}

// ============================================================
// DOMAIN 4: EMPLOYEE MASTER
// ============================================================

model Employee {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                 String           @map("org_id") @db.Uuid
  employeeCode          String           @map("employee_code") @db.VarChar(30)
  userAccountId         String?          @unique @map("user_account_id") @db.Uuid
  firstName             String           @map("first_name") @db.VarChar(100)
  middleName            String?          @map("middle_name") @db.VarChar(100)
  lastName              String           @map("last_name") @db.VarChar(100)
  preferredName         String?          @map("preferred_name") @db.VarChar(100)
  dateOfBirth           DateTime         @map("date_of_birth") @db.Date
  gender                Gender
  bloodGroup            String?          @map("blood_group") @db.VarChar(5)
  nationality           String           @default("Indian") @db.VarChar(50)
  maritalStatus         MaritalStatus?   @map("marital_status")
  personalEmail         String?          @map("personal_email") @db.VarChar(200)
  workEmail             String?          @map("work_email") @db.VarChar(200)
  personalPhone         String?          @map("personal_phone") @db.VarChar(15)
  workPhone             String?          @map("work_phone") @db.VarChar(15)
  // Encrypted sensitive fields
  panEncrypted          Bytes?           @map("pan_encrypted")
  panLast4              String?          @map("pan_last4") @db.VarChar(4)
  aadhaarEncrypted      Bytes?           @map("aadhaar_encrypted")
  aadhaarLast4          String?          @map("aadhaar_last4") @db.VarChar(4)
  uanNumber             String?          @map("uan_number") @db.VarChar(12)
  esiIpNumber           String?          @map("esi_ip_number") @db.VarChar(20)
  passportNumber        String?          @map("passport_number") @db.VarChar(20)
  passportExpiry        DateTime?        @map("passport_expiry") @db.Date
  // Employment
  branchId              String           @map("branch_id") @db.Uuid
  departmentId          String           @map("department_id") @db.Uuid
  teamId                String?          @map("team_id") @db.Uuid
  designationId         String           @map("designation_id") @db.Uuid
  gradeId               String?          @map("grade_id") @db.Uuid
  costCenterId          String?          @map("cost_center_id") @db.Uuid
  locationId            String?          @map("location_id") @db.Uuid
  shiftId               String?          @map("shift_id") @db.Uuid
  reportingManagerId    String?          @map("reporting_manager_id") @db.Uuid
  dottedLineManagerId   String?          @map("dotted_line_manager_id") @db.Uuid
  employmentType        EmploymentType   @default(FULL_TIME) @map("employment_type")
  employmentStatus      EmploymentStatus @default(ACTIVE) @map("employment_status")
  dateOfJoining         DateTime         @map("date_of_joining") @db.Date
  dateOfConfirmation    DateTime?        @map("date_of_confirmation") @db.Date
  probationPeriodMonths Int              @default(3) @map("probation_period_months") @db.SmallInt
  dateOfExit            DateTime?        @map("date_of_exit") @db.Date
  // Statutory flags
  epfApplicable         Boolean          @default(true) @map("epf_applicable")
  esiApplicable         Boolean          @default(true) @map("esi_applicable")
  ptApplicable          Boolean          @default(true) @map("pt_applicable")
  lwfApplicable         Boolean          @default(true) @map("lwf_applicable")
  tdsApplicable         Boolean          @default(true) @map("tds_applicable")
  isDirector            Boolean          @default(false) @map("is_director")
  profilePhotoUrl       String?          @map("profile_photo_url")
  bio                   String?
  linkedinUrl           String?          @map("linkedin_url") @db.VarChar(300)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  createdBy             String?          @map("created_by") @db.Uuid
  updatedBy             String?          @map("updated_by") @db.Uuid
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz
  isDeleted             Boolean          @default(false) @map("is_deleted")
  version               Int              @default(1)

  org                   Organization            @relation(fields: [orgId], references: [id])
  branch                Branch                  @relation(fields: [branchId], references: [id])
  department            Department              @relation(fields: [departmentId], references: [id])
  team                  Team?                   @relation(fields: [teamId], references: [id])
  designation           Designation             @relation(fields: [designationId], references: [id])
  grade                 Grade?                  @relation(fields: [gradeId], references: [id])
  costCenter            CostCenter?             @relation(fields: [costCenterId], references: [id])
